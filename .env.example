# Node configuration
NODE_ENV=development

# Postgres Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_MULTIPLE_DATABASES=auth,profiles,products,carts,orders,payments,notifications
POSTGRES_FORWARD_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Minio Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_FORWARD_PORT=9000
MINIO_CONSOLE_FORWARD_PORT=9001
MINIO_BUCKET_NAME=ecom-bucket
MINIO_PUBLIC_URL=http://localhost:${MINIO_FORWARD_PORT}

# Logger Service Configuration
LOG_LEVEL=info
LOG_RETENTION_DAYS=7

# Auth Service Configuration
AUTH_SERVICE_PORT=4001
AUTH_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@ecom-postgres:5432/auth?schema=public
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5